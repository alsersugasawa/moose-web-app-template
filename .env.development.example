# ─────────────────────────────────────────────────────────────────────────────
# Development profile — loaded when APP_ENV=development
# Copy to .env.development and adjust as needed.
# Only list values that differ from your .env base file.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=development
ENVIRONMENT=development

# Shorter token expiry speeds up testing sessions
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Relax security headers (avoids CSP issues with hot-reload tooling)
SECURITY_HEADERS_ENABLED=false

# Keep rate limiting on but can be disabled locally if it gets in the way
RATE_LIMIT_ENABLED=true

# Relaxed CORS for local tooling
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173
TRUSTED_HOSTS=localhost,127.0.0.1,*.localhost
