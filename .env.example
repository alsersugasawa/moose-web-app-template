# ─────────────────────────────────────────────────────────────────────────────
# Web Platform Template — Environment Configuration
# Copy this file to .env and fill in your values.
#
# Profile overlays:
#   .env.development  — loaded when APP_ENV=development (default)
#   .env.staging      — loaded when APP_ENV=staging
#   .env.production   — loaded when APP_ENV=production
#
# Values in the profile file override values in .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────

# Active environment profile: development | staging | production
APP_ENV=development

# FastAPI mode: 'development' exposes /docs and /redoc; 'production' hides them
ENVIRONMENT=development

# REQUIRED: Random 32+ character string used to sign JWT tokens and sessions.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-secret-key

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/webapp

# JWT token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Registration ──────────────────────────────────────────────────────────────

# Set to 'true' to require an admin-issued invitation token for registration
INVITE_ONLY=false

# ── CORS & Trusted Hosts ──────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Comma-separated list of trusted Host header values (use *.domain.com for wildcards)
TRUSTED_HOSTS=localhost,127.0.0.1,*.localhost

# ── Security Middleware ───────────────────────────────────────────────────────

# Enable security headers (HSTS, CSP, X-Frame-Options, etc.)
SECURITY_HEADERS_ENABLED=true

# Enable per-IP rate limiting
RATE_LIMIT_ENABLED=true

# ── Email / SMTP ──────────────────────────────────────────────────────────────

# SMTP server hostname
SMTP_HOST=smtp.example.com

# SMTP port (587 = STARTTLS, 465 = SSL/TLS, 25 = plaintext)
SMTP_PORT=587

# SMTP authentication credentials
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# From address for outgoing emails
SMTP_FROM=noreply@example.com

# Use STARTTLS (true/false)
SMTP_TLS=true

# ── OAuth 2.0 — Google ────────────────────────────────────────────────────────

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth/google/callback

# ── OAuth 2.0 — GitHub ────────────────────────────────────────────────────────

OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/oauth/github/callback

# ── Backups ───────────────────────────────────────────────────────────────────

# Directory where backups are stored inside the container
BACKUP_DIR=/app/backups

# How many days to keep local backups
BACKUP_RETENTION_DAYS=30

# SMB/CIFS share backup (optional)
SMB_BACKUP_ENABLED=false
SMB_HOST=
SMB_SHARE=
SMB_USERNAME=
SMB_PASSWORD=
SMB_MOUNT_POINT=/mnt/smb_backups

# NFS share backup (optional)
NFS_BACKUP_ENABLED=false
NFS_HOST=
NFS_EXPORT=
NFS_MOUNT_POINT=/mnt/nfs_backups

# ── Caddy (reverse proxy) ─────────────────────────────────────────────────────

# Caddy admin API URL (used for certificate management)
CADDY_ADMIN_URL=http://caddy:2019
