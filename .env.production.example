# ─────────────────────────────────────────────────────────────────────────────
# Production profile — loaded when APP_ENV=production
# Copy to .env.production and adjust as needed.
# Only list values that differ from your .env base file.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=production
ENVIRONMENT=production    # Hides /docs and /redoc

ACCESS_TOKEN_EXPIRE_MINUTES=30

SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true

# Replace with your production domain
CORS_ORIGINS=https://app.example.com
TRUSTED_HOSTS=app.example.com,www.app.example.com

INVITE_ONLY=true

# Enforce strict backup retention
BACKUP_RETENTION_DAYS=90
