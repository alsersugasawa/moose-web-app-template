# ─────────────────────────────────────────────────────────────────────────────
# Staging profile — loaded when APP_ENV=staging
# Copy to .env.staging and adjust as needed.
# Only list values that differ from your .env base file.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=staging
ENVIRONMENT=development   # Keep /docs available for QA; change to 'production' to hide

ACCESS_TOKEN_EXPIRE_MINUTES=60

SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true

# Replace with your staging domain
CORS_ORIGINS=https://staging.example.com
TRUSTED_HOSTS=staging.example.com

INVITE_ONLY=true
